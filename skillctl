#!/usr/bin/env python3
"""skillctl — 관리 스킬 활성/보관 전환기"""
import sqlite3, shutil, sys, os
from pathlib import Path

HOME = Path.home()
SKILLS = HOME / ".hermes" / "skills"
ARCHIVE = HOME / ".hermes" / "archive-skills"
DB = HOME / ".hermes" / "skill_registry.db"
EXT = HOME / ".hermes" / "skills" / "external" / "scientific-agent-skills" / "scientific-skills"

def conn():
    return sqlite3.connect(DB)

def init():
    c = conn()
    c.execute("CREATE TABLE IF NOT EXISTS skills (name TEXT PRIMARY KEY, location TEXT, category TEXT, description TEXT, tags TEXT)")
    c.execute("DELETE FROM skills")
    count = 0
    for base, label in [(SKILLS, "active"), (ARCHIVE, "archive")]:
        for sk in base.rglob("SKILL.md"):
            name = sk.parent.relative_to(base).as_posix()
            cat = sk.parent.parent.relative_to(base).as_posix() if sk.parent.parent != base else "root"
            desc = ""
            tags = ""
            for line in sk.read_text().splitlines():
                if line.startswith("description:"):
                    desc = line[len("description:"):].strip().strip("\"'")
                elif line.startswith("tags:"):
                    tags = line[len("tags:"):].strip().strip("[]").replace(",", " ")
            c.execute("INSERT OR REPLACE INTO skills VALUES (?,?,?,?,?)", (name, label, cat, desc, tags))
            count += 1
    # external scientific skills (flat under EXT)
    if EXT.exists():
        for sk in EXT.rglob("SKILL.md"):
            name = f"external/{sk.parent.name}"
            desc = ""
            tags = ""
            for line in sk.read_text().splitlines():
                if line.startswith("description:"):
                    desc = line[len("description:"):].strip().strip("\"'")
                elif line.startswith("tags:"):
                    tags = line[len("tags:"):].strip().strip("[]").replace(",", " ")
            c.execute("INSERT OR REPLACE INTO skills VALUES (?,?,?,?,?)", (name, "active", "external", desc, tags))
            count += 1
    c.commit(); c.close()
    print(f"✅ {count} skills indexed")

def search(query):
    c = conn()
    like = f"%{query}%"
    rows = c.execute("SELECT name, location, description FROM skills WHERE name LIKE ? OR description LIKE ? OR tags LIKE ? LIMIT 30", (like, like, like)).fetchall()
    c.close()
    if not rows: print("❌ Not found"); return
    for name, loc, desc in rows:
        icon = "📦" if loc == "archive" else "⚡"
        print(f"  {icon} {name}  ({loc})")
        if desc: print(f"     {desc[:80]}")

def install(name):
    src = ARCHIVE / name
    dst = SKILLS / name
    if not src.exists():
        # check relative path
        for p in ARCHIVE.rglob(f"{name}/SKILL.md"):
            src = p.parent; break
        else:
            print(f"❌ {name} not in archive"); return
    dst.parent.mkdir(parents=True, exist_ok=True)
    shutil.copytree(src, dst, dirs_exist_ok=True)
    print(f"✅ {name} installed (now in context)")
    c = conn()
    c.execute("UPDATE skills SET location='active' WHERE name=?", (name,))
    c.commit(); c.close()

def remove(name):
    src = SKILLS / name
    if not src.exists():
        for p in SKILLS.rglob(f"{name}/SKILL.md"):
            src = p.parent; break
        else:
            print(f"❌ {name} not active"); return
    dst = ARCHIVE / name
    dst.parent.mkdir(parents=True, exist_ok=True)
    shutil.move(str(src), str(dst))
    print(f"✅ {name} archived (out of context)")
    c = conn()
    c.execute("UPDATE skills SET location='archive' WHERE name=?", (name,))
    c.commit(); c.close()

def status():
    c = conn()
    a = c.execute("SELECT COUNT(*) FROM skills WHERE location='active'").fetchone()[0]
    ar = c.execute("SELECT COUNT(*) FROM skills WHERE location='archive'").fetchone()[0]
    c.close()
    print(f"⚡ Active: {a}  📦 Archived: {ar}  ∑ {a+ar}")

def list_skills(all_flag):
    c = conn()
    where = "" if all_flag else "WHERE location='active'"
    rows = c.execute(f"SELECT name, location FROM skills {where} ORDER BY name").fetchall()
    c.close()
    for name, loc in rows:
        icon = "📦" if loc == "archive" else "⚡"
        print(f"  {icon} {name}")

if __name__ == "__main__":
    if len(sys.argv) < 2 or sys.argv[1] in ("-h", "--help"):
        print("Usage: skillctl <command> [args]")
        print("  init          — scan & index all skills")
        print("  search <q>    — search registry")
        print("  install <n>   — archive → active")
        print("  remove <n>    — active → archive")
        print("  list [--all]  — show active (or all)")
        print("  status        — active/archive counts")
        sys.exit(0)
    cmd = sys.argv[1]
    if cmd == "init": init()
    elif cmd == "search": search(" ".join(sys.argv[2:]))
    elif cmd == "install": install(sys.argv[2])
    elif cmd == "remove": remove(sys.argv[2])
    elif cmd == "list": list_skills("--all" in sys.argv)
    elif cmd == "status": status()
    else: print(f"Unknown: {cmd}")
